# ─── From the Forest HTML project launch "congratulations" screen (shown ONCE) ───
# Also visible later (base URL only) in the project editor's HTML Settlement card.
FOREST_API_BASE_URL=https://api.forest.example
SETTLEMENT_SECRET=fsc_live_xxxxxxxxxxxxxxxxxxxxx
PROJECT_ID=your-forest-project-id

# ─── Your own secrets ───
# Long random string used to sign player session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# ─── CORS ───
# The exact origin your game iframe is served from (the Forest token-page domain).
# Comma-separate multiple origins. Use * ONLY for local testing.
ALLOWED_ORIGIN=*

# ─── Provided automatically by the Railway Postgres plugin ───
DATABASE_URL=postgresql://user:pass@host:5432/railway

# ─── Optional ───
TOKEN_DECIMALS=18      # $GARDEN base-unit decimals (wei-style)
PGSSL=false            # set true if connecting to Postgres over public network
PORT=3000
